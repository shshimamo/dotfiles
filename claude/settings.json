{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(bash -c:*)",
      "Bash(echo:*)",
      "Bash(cd:*)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /*)",
      "Bash(git -C:*)",
      "Bash(git --git-dir:*)",
      "Bash(git --work-tree:*)",
      "Bash(git add .:*)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.envrc)",
      "Read(./.envrc.*)",
      "Read(./secrets/**)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "todo@shshimamo-plugins": true
  },
  "extraKnownMarketplaces": {
    "shshimamo-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/shshimamo/claude-plugins.git"
      }
    }
  },
  "language": "japanese",
  "autoUpdatesChannel": "stable"
}
